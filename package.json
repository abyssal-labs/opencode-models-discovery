{
  "name": "@abyssal-labs/opencode-models-discovery",
  "version": "0.1.2",
  "description": "opencode plugin that refreshes OpenAI-compatible model metadata from /models endpoints",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "openai-compatible",
    "model-discovery"
  ],
  "homepage": "https://github.com/abyssal-labs/opencode-models-discovery#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abyssal-labs/opencode-models-discovery.git"
  },
  "bugs": {
    "url": "https://github.com/abyssal-labs/opencode-models-discovery/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "node --test --experimental-strip-types test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opencode-ai/plugin": "^1.17.18",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^25.0.3",
    "eslint": "^10.6.0",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  },
  "license": "MIT"
}
