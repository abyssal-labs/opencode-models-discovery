{
  "name": "@abyssal-labs/opencode-models-discovery",
  "version": "0.8.0",
  "description": "Automatically discover available provider models and metadata in OpenCode",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "openai-compatible",
    "anthropic-compatible",
    "amazon-bedrock",
    "cloudflare-workers-ai",
    "cohere",
    "dynamic-models",
    "google-gemini",
    "llm-gateway",
    "llm-proxy",
    "model-discovery",
    "vercel-ai-gateway"
  ],
  "homepage": "https://github.com/abyssal-labs/opencode-models-discovery#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abyssal-labs/opencode-models-discovery.git"
  },
  "bugs": {
    "url": "https://github.com/abyssal-labs/opencode-models-discovery/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format:check": "prettier --check .",
    "lint": "oxlint --deny-warnings .",
    "test": "node --test --experimental-strip-types test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.18.4",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^26.1.1",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.3",
    "typescript": "^7.0.2"
  },
  "license": "MIT"
}
